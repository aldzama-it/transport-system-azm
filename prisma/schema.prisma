// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  koor_transport
  staff_transport
}

enum RequestStatus {
  pending
  granted
  deny
  cancelled
  done
}

model StaffAkun {
  id           Int      @id @default(autoincrement())
  nama         String
  email        String   @unique
  passwordHash String
  role         Role     @default(staff_transport)
  createdAt    DateTime @default(now())
  histories    RequestHistory[]
}

model Driver {
  id       Int      @id @default(autoincrement())
  nama     String
  telepon  String?
  status   String   @default("aktif")
  requests Request[]
}

model Kendaraan {
  id       Int      @id @default(autoincrement())
  jenis    String
  nopol    String   @unique
  status   String   @default("tersedia")
  project  String?
  lokasi   String?
  requests Request[]
}

model Request {
  id            Int             @id @default(autoincrement())
  noForm        String          @unique
  namaPemohon   String
  divisi        String
  tujuan        String          @db.Text
  tglMulai      DateTime?
  tglSelesai    DateTime?
  status        RequestStatus   @default(pending)
  driverId      Int?
  driver        Driver?         @relation(fields: [driverId], references: [id])
  kendaraanId   Int?
  kendaraan     Kendaraan?      @relation(fields: [kendaraanId], references: [id])
  buktiFileUrl  String?
  alasanDeny    String?         @db.Text
  alasanCancel  String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  history       RequestHistory[]

  @@index([status])
}

model RequestHistory {
  id        Int           @id @default(autoincrement())
  requestId Int
  request   Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  staffId   Int?
  staff     StaffAkun?    @relation(fields: [staffId], references: [id])
  status    RequestStatus
  catatan   String?       @db.Text
  createdAt DateTime      @default(now())
}